{
  "manifest_version": 3,
  "name": "Facsimile - URL to Design",
  "version": "1.0.0",
  "description": "Capture any web page and paste it into Figma as an editable design.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/toolbar-16.png",
      "48": "icons/toolbar-48.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://mcp.figma.com/*"]
}
