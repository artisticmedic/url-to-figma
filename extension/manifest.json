{
  "manifest_version": 3,
  "name": "Facsimile",
  "version": "1.0.0",
  "description": "Capture any web page and paste it into Figma as an editable design.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://mcp.figma.com/*"]
}
